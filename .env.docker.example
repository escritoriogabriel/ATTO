# ============================================
# ATTO Transcriber - Configuração Docker Local
# ============================================
# Copie este arquivo para .env.docker e customize conforme necessário

# Database Configuration
DB_HOST=mysql
DB_PORT=3306
DB_USER=atto_user
DB_PASSWORD=atto_password
DB_NAME=atto_db
DB_ROOT_PASSWORD=root

# Application
NODE_ENV=development
APP_PORT=3000
VITE_PORT=5173

# JWT & Security
JWT_SECRET=dev-secret-key-change-in-production

# OAuth (Manus)
VITE_APP_ID=local-dev
OAUTH_SERVER_URL=http://localhost:3000
VITE_OAUTH_PORTAL_URL=http://localhost:3000
OWNER_OPEN_ID=dev-owner
OWNER_NAME=Developer

# Manus Built-in APIs
BUILT_IN_FORGE_API_URL=http://localhost:3000
BUILT_IN_FORGE_API_KEY=dev-key
VITE_FRONTEND_FORGE_API_URL=http://localhost:3000
VITE_FRONTEND_FORGE_API_KEY=dev-key

# Upload Configuration
MAX_UPLOAD_SIZE=524288000
UPLOAD_TEMP_DIR=/tmp/atto-uploads
